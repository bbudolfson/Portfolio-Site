{
  "name": "portfolio",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=20 <21"
  },
  "scripts": {
    "up": "bash scripts/up.sh",
    "setup": "npm install",
    "optimize-images": "node scripts/optimize-project-images.mjs",
    "optimize-case-study": "node scripts/optimize-case-study-pdf.mjs",
    "optimize-resume": "node scripts/optimize-resume-pdf.mjs",
    "prebuild": "rm -rf out && npm run optimize-images && npm run optimize-case-study && npm run optimize-resume",
    "dev": "STATIC_EXPORT=false WATCHPACK_POLLING=true next dev --webpack -p ${PORT:-3000}",
    "dev:local": "bash scripts/dev-with-tools.sh",
    "dev:reset": "bash scripts/dev-reset.sh",
    "preview": "STATIC_EXPORT=true next build && node scripts/serve-out.mjs",
    "preview:local": "bash scripts/preview-with-tools.sh",
    "build": "STATIC_EXPORT=true next build",
    "start": "STATIC_EXPORT=false next start -p ${PORT:-3000}",
    "lint": "next lint"
  },
  "dependencies": {
    "embla-carousel-react": "*",
    "framer-motion": "*",
    "next": "*",
    "react": "*",
    "react-dom": "*",
    "react-markdown": "*",
    "react-pdf": "^10.4.1"
  },
  "devDependencies": {
    "@types/node": "*",
    "@types/react": "*",
    "@types/react-dom": "*",
    "netlify-cli": "^24.3.0",
    "pdf-to-img": "^6.2.0",
    "sharp": "^0.35.1",
    "typescript": "*"
  }
}
